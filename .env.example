INPUT_FOLDER=./input_folder
PROCESSED_FOLDER=./processed
FAILED_FOLDER=./failed
LOGS_FOLDER=./logs
LOG_FILE=./logs/pipeline.log
LOG_LEVEL=INFO
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=10

QUEUE_MAX_SIZE=5000
WORKER_MULTIPLIER=2
WORKER_COUNT_OVERRIDE=0
RETRY_LIMIT=2

DB_BATCH_SIZE=50
DB_BATCH_FLUSH_SECONDS=2

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=Lisolo123.
MYSQL_DATABASE=parsxdb
MYSQL_POOL_NAME=bl_pool
# Optional: cap this app's DB usage (workers each use 1 conn; writer uses 1). 0 = no cap.
# Use when the server has low max_connections or many other clients.
# MYSQL_CONNECTION_BUDGET=40

# Only if you enable use_pool=True on DatabaseClient (writer uses single conn by default).
MYSQL_POOL_SIZE=2

MIN_PDF_TEXT_CHARS=100
STATS_INTERVAL_SECONDS=60

MONITOR_ENABLED=true
MONITOR_HOST=127.0.0.1
MONITOR_PORT=8765
MONITOR_BROADCAST_SECONDS=1

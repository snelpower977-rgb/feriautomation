INPUT_FOLDER=./input_folder
PROCESSED_FOLDER=./processed
FAILED_FOLDER=./failed
SKIPPED_FOLDER=./skipped
LOGS_FOLDER=./logs
LOG_FILE=./logs/pipeline.log
LOG_LEVEL=INFO
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=10

QUEUE_MAX_SIZE=5000
WORKER_MULTIPLIER=2
WORKER_COUNT_OVERRIDE=0
RETRY_LIMIT=2
AI_EXTRA_RETRIES=3
AI_RETRY_BACKOFF_MAX_SECONDS=30
DEDUP_ENABLED=true
STORE_PROCESSED_ONLY=true
# Limite la concurrence IA (recommandé pour fichiers volumineux)
AI_MAX_CONCURRENT_WORKERS=4
WORKER_COUNT_OVERRIDE=0
# Validation qualité extraction (évite les lignes "processed" quasi vides)
MIN_STRUCTURED_FIELDS=2
# Seuil plus bas en OCR_ONLY_MODE (regex sur texte bruité)
MIN_STRUCTURED_FIELDS_OCR=1
FILE_STABILITY_CHECKS=4
FILE_STABILITY_DELAY_SECONDS=0.8
MIN_PROCESSING_SECONDS=20
MAX_PROCESSING_SECONDS=45
PROCESSING_SCALE_MAX_MB=20

DB_BATCH_SIZE=50
DB_BATCH_FLUSH_SECONDS=2

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=Lisolo123.
MYSQL_DATABASE=parsxdb
MYSQL_POOL_NAME=bl_pool
# Optional: cap this app's DB usage (workers each use 1 conn; writer uses 1). 0 = no cap.
# Use when the server has low max_connections or many other clients.
# MYSQL_CONNECTION_BUDGET=40

# Only if you enable use_pool=True on DatabaseClient (writer uses single conn by default).
MYSQL_POOL_SIZE=2

MIN_PDF_TEXT_CHARS=100
OCR_ONLY_MODE=false
# OCR avancé (Tesseract) — PDF scannés & images
OCR_PDF_DPI=300
# 0 = toutes les pages
OCR_MAX_PDF_PAGES=0
OCR_TESSERACT_LANG=eng
# OEM 3 = LSTM par défaut. PSM: séparation de page (voir doc tesseract)
OCR_TESSERACT_OEM=3
OCR_TESSERACT_PSM=6,4,11,3
OCR_MAX_TESSERACT_CALLS_PER_PAGE=12
OCR_MIN_SIDE_UPSCALE=1400
OCR_UPSCALE_TARGET_MIN_SIDE=1800
OCR_UPSCALE_MAX_SIDE=4000
STATS_INTERVAL_SECONDS=60

MONITOR_ENABLED=true
MONITOR_HOST=127.0.0.1
MONITOR_PORT=8765
MONITOR_BROADCAST_SECONDS=1

# OpenAI (optional) — extraction IA; never commit real keys
OPENAI_API_KEY=
# true = champs structurés via OpenAI si la clé est définie (prime sur OPENAI_OVERRIDE_BL_FIELDS)
OPENAI_EXTRACTION=true
# false = aucune regex sur les champs B/L (défaut : IA ou champs NULL). true = repli regex sans clé / sans IA.
OPENAI_REGEX_FALLBACK=false
OPENAI_MODEL=gpt-4o-mini
# Plus le document est long, monter la valeur (plafond coût tokens)
OPENAI_MAX_INPUT_CHARS=24000
# Envoi des pages en image + OCR (recommandé pour B/L scannés). false = texte seul.
OPENAI_USE_VISION=true
OPENAI_VISION_MAX_PAGES=3
OPENAI_VISION_MAX_SIDE=1800
OPENAI_VISION_DPI=160
OPENAI_VISION_JPEG_QUALITY=82

# Gemini (prioritaire si GEMINI_EXTRACTION=true et GEMINI_API_KEY renseignee)
GEMINI_API_KEY=
GEMINI_EXTRACTION=false
GEMINI_REGEX_FALLBACK=false
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MAX_INPUT_CHARS=24000
GEMINI_TIMEOUT_SECONDS=180
GEMINI_USE_VISION=true
GEMINI_VISION_MAX_PAGES=3
GEMINI_VISION_MAX_SIDE=1800
GEMINI_VISION_DPI=160
GEMINI_VISION_JPEG_QUALITY=82

# DeepSeek (prioritaire sur Gemini/OpenAI si DEEPSEEK_EXTRACTION=true)
DEEPSEEK_API_KEY=
DEEPSEEK_EXTRACTION=true
DEEPSEEK_REGEX_FALLBACK=false
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_MAX_INPUT_CHARS=24000
DEEPSEEK_TIMEOUT_SECONDS=180
DEEPSEEK_API_KEY=sk-f0f8a8bf390246b4b974760fde9e7aa2